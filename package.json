{
  "name": "llm-wiki-skills",
  "version": "0.1.1",
  "description": "Local-first CLI for installing host-specific LLM wiki skills.",
  "type": "module",
  "license": "MIT",
  "author": "weiiiii0622",
  "bin": {
    "llm-wiki-skills": "bin/llm-wiki-skills"
  },
  "files": [
    "dist",
    "bin",
    "fixtures/demo-vault",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && vitest run",
    "pack:dry-run": "npm run build && npm pack --dry-run --cache .tmp/npm-cache",
    "smoke": "npm run build && node -e \"fs.rmSync('.tmp/smoke', { recursive: true, force: true })\" && node bin/llm-wiki-skills init --root .tmp/smoke --host codex --quiet && node bin/llm-wiki-skills status --root .tmp/smoke --json",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "llm",
    "wiki",
    "obsidian",
    "codex",
    "claude",
    "skills"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weiiiii0622/llm-wiki-skills.git"
  }
}
